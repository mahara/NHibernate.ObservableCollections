<Project>

  <!--
    TARGETS
  -->

  <Target Name="Project_Project_BuildPropertiesDisplay_BeforeProjectBuild"
          BeforeTargets="BeforeBuild"
          Condition="'$(IsCrossTargetingBuild)' != 'true'">
    <Message Text="$(MSBuildProjectName) ($(Configuration)\$(TargetFramework)):%0D%0A  WorkspaceFolderPath = '$(WorkspaceFolderPath)'%0D%0A  ArtifactsFolderPath = '$(ArtifactsFolderPath)'%0D%0A  BaseIntermediateOutputBaseFolderPath = '$(BaseIntermediateOutputBaseFolderPath)'%0D%0A  BaseIntermediateOutputPath = '$(BaseIntermediateOutputPath)'%0D%0A  MSBuildProjectExtensionsPath = '$(MSBuildProjectExtensionsPath)'%0D%0A  IntermediateOutputPath = '$(IntermediateOutputPath)'%0D%0A  BaseOutputBaseFolderPath = '$(BaseOutputBaseFolderPath)'%0D%0A  BaseOutputPath = '$(BaseOutputPath)'%0D%0A  OutputBaseFolderPath = '$(OutputBaseFolderPath)'%0D%0A  OutputPath = '$(OutputPath)'%0D%0A  OutDir = '$(OutDir)'"
             Importance="high" />
  </Target>

  <!--
    Clean temporary WPF project directories ("$(MSBuildProjectName)_*_wpftmp") left after build.

    https://github.com/dotnet/wpf/issues/2930
  -->
  <Target Name="Project_Project_WpfTmpProjectsCleanup_AfterProjectBuild"
          AfterTargets="AfterBuild"
          Condition="'$(IsCrossTargetingBuild)' != 'true' AND '$(UseWPF)' == 'true'">
    <Message Text="$(MSBuildProjectName): Starting WPF '*_wpftmp' projects cleanup..."
             Importance="high" />

    <!-- bin -->
    <ItemGroup Condition="Exists('$(OutputBaseFolderPath)')">
      <_WpfTmpBinDirectories Include="$([System.IO.Directory]::GetDirectories('$(OutputBaseFolderPath)', '$(MSBuildProjectName)_*_wpftmp'))" />
    </ItemGroup>
    <RemoveDir Directories="@(_WpfTmpBinDirectories)"
               ContinueOnError="true" />

    <!-- obj -->
    <ItemGroup Condition="Exists('$(BaseIntermediateOutputBaseFolderPath)')">
      <_WpfTmpObjDirectories Include="$([System.IO.Directory]::GetDirectories('$(BaseIntermediateOutputBaseFolderPath)', '$(MSBuildProjectName)_*_wpftmp'))" />
    </ItemGroup>
    <RemoveDir Directories="@(_WpfTmpObjDirectories)"
               ContinueOnError="true" />

    <Message Text="$(MSBuildProjectName): Finished WPF '*_wpftmp' projects cleanup."
             Importance="high" />
  </Target>

  <!--
    Solution-level deep cleanup executed from project-level Clean target anchors.

    MSBuild/Visual Studio does not provide a reliable solution-level AfterClean hook.
    Therefore this target intentionally performs idempotent multi-pass cleanup from
    each participating project/TargetFramework Clean execution.

    This can run multiple times during a solution clean:

        projects × target frameworks

    The repeated execution is intentional and must remain safe.
  -->
  <Target Name="Project_Solution_DeepCleanup_AfterProjectClean"
          AfterTargets="AfterClean">
    <Message Text="$(MSBuildProjectName) [TargetFramework='$(TargetFramework)', TargetFrameworks='$(TargetFrameworks)', IsCrossTargetingBuild='$(IsCrossTargetingBuild)']: Starting solution deep cleanup..."
             Importance="high" />

    <!--
      https://stackoverflow.com/questions/1088593/how-to-clean-visual-studio-bin-and-obj-folders
      https://stackoverflow.com/questions/755382/i-want-to-delete-all-bin-and-obj-folders-to-force-all-projects-to-rebuild-everyt
    -->

    <!-- bin -->
    <RemoveDir Directories="$(BaseOutputBaseFolderPath)"
               Condition="Exists('$(BaseOutputBaseFolderPath)')"
               ContinueOnError="true" />

    <!-- obj -->
    <RemoveDir Directories="$(BaseIntermediateOutputBaseFolderPath)"
               Condition="Exists('$(BaseIntermediateOutputBaseFolderPath)')"
               ContinueOnError="true" />

    <Message Text="$(MSBuildProjectName): Finished solution deep cleanup."
             Importance="high" />
  </Target>

</Project>
