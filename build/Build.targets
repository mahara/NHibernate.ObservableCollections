<Project>

  <!--
    TARGETS
  -->

  <Target Name="DeepCleanProjectAfterClean" AfterTargets="Clean">
    <Message Text="Deep cleaning project $(MSBuildProjectName) on cleaning..." />

    <!--
      https://stackoverflow.com/questions/1088593/how-to-clean-visual-studio-bin-and-obj-folders
    -->
    <!-- bin -->
    <RemoveDir Directories="$(OutputFolderPath)" ContinueOnError="true" />
    <!-- obj -->
    <RemoveDir Directories="$(IntermediateOutputFolderPath)" ContinueOnError="true" />
    <!-- .vs -->
    <!-- <RemoveDir Directories="$(SolutionDir)\.vs"
               ContinueOnError="true" /> -->
  </Target>

</Project>
