<Window x:Class="NHibernate.ObservableCollections.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Example"
        Height="425.6"
        Width="650"
        Background="LightGray"
        Loaded="this_Loaded"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Grid DockPanel.Dock="Bottom"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Name="editItemBox"
                     Margin="10,0,10,10" />
            <WrapPanel Grid.Row="1">
                <Button Name="addItemButton"
                        Content="Insert New"
                        Click="addButton_Click"
                        Padding="5,2"
                        Margin="10,0,10,10" />
                <Button Name="updateItemButton"
                        Content="Update"
                        Click="updateButton_Click"
                        Padding="5,2"
                        Margin="0,0,10,10" />
                <Button Name="deleteItemButton"
                        Content="Delete"
                        Click="deleteButton_Click"
                        Padding="5,2"
                        Margin="0,0,10,10" />
                <Button Name="copyItemToButton"
                        Content="Copy To -&gt;"
                        Click="copyToButton_Click"
                        Padding="5,2"
                        Margin="0,0,10,10" />
            </WrapPanel>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <DockPanel>
                <Label Name="sampleSetLabel"
                       Content="Sample Set"
                       FontWeight="Bold"
                       DockPanel.Dock="Top"
                       HorizontalContentAlignment="Center" />
                <ListBox Name="sampleSetBox"
                         DisplayMemberPath="Name"
                         SelectionChanged="ItemSelectionChange"
                         Margin="20,0,20,10" />
            </DockPanel>
            <DockPanel Grid.Column="1">
                <Label Name="sampleListLabel"
                       Content="Sample List"
                       FontWeight="Bold"
                       DockPanel.Dock="Top"
                       HorizontalContentAlignment="Center" />
                <ListBox Name="sampleListBox"
                         DisplayMemberPath="Name"
                         SelectionChanged="ItemSelectionChange"
                         Margin="20,0,20,10" />
            </DockPanel>
        </Grid>
    </DockPanel>

</Window>